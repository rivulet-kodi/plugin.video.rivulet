<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<window>
    <depth>0.52</depth>
    <coordinates><left>0</left><top>0</top></coordinates>
    <controls>
        <control type="group">
            <left>0</left><top>0</top>
            <animation type="WindowOpen" reversible="false">
                <effect type="slide" start="0,100" end="0,0" delay="160" time="160" />
                <effect type="fade" delay="160" end="100" time="100" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="slide" start="0,0" end="0,100" delay="160" time="160" />
                <effect type="fade" delay="160" start="100" end="0" time="100" />
            </animation>
            <control type="image"><width>1280</width><height>720</height><texture colordiffuse="E6111111">white.png</texture></control>
            <control type="image" id="30000"><width>1280</width><height>720</height><texture colordiffuse="FF555555"></texture><aspectratio>scale</aspectratio></control>
            <control type="image"><width>1280</width><height>720</height><texture colordiffuse="99000000">white.png</texture></control>
            <control type="image" id="30001"><top>355</top><left>490</left><width>300</width><height>10</height><texture>white.png</texture>
                <animation effect="zoom" pulse="true" center="auto" start="0,100" end="100,100" time="1000" condition="Control.IsVisible(30001)">Conditional</animation>
            </control>
            <control type="label"><right>110</right><top>36</top><width>240</width><height>30</height><font>font13</font><textcolor>AAFFFFFF</textcolor><align>right</align>
                <label>$INFO[Container(30002).CurrentItem]/$INFO[Container(30002).NumItems]</label>
            </control>
            <control type="fixedlist" id="30002">
                <top>40</top><width>100%</width><height>640</height>
                <viewtype>wrap</viewtype><orientation>horizontal</orientation>
                <scrolltime tween="cubic" easing="out">300</scrolltime>
                <onup>30003</onup>
                <itemlayout width="180">
                    <control type="image">
                        <top>360</top><left>0</left><width>180</width><height>245</height>
                        <texture colordiffuse="CCFFFFFF">$INFO[ListItem.Property(thumbnail)]</texture>
                        <aspectratio>scale</aspectratio>
                    </control>
                    <control type="label">
                        <top>608</top><left>0</left><width>180</width><height>20</height>
                        <font>font10</font><textcolor>CCFFFFFF</textcolor><align>center</align>
                        <label>$INFO[ListItem.Label]</label>
                    </control>
                </itemlayout>
                <focusedlayout width="380">
                    <control type="image">
                        <top>66</top><left>-4</left><width>388</width><height>568</height>
                        <texture colordiffuse="FF3AA0FF">white.png</texture>
                    </control>
                    <control type="image">
                        <top>70</top><left>0</left><width>380</width><height>560</height>
                        <texture>$INFO[ListItem.Property(thumbnail)]</texture>
                        <aspectratio>scale</aspectratio>
                    </control>
                    <control type="textbox"><left>447</left><top>10</top><width>783</width><height>34</height><font>font13</font><textcolor>FFFFFFFF</textcolor>
                        <label>[B]$INFO[ListItem.Label][/B] [COLOR FFAAAAAA]$INFO[ListItem.Property(year)][/COLOR] [COLOR FFE5A00D]$INFO[ListItem.Property(rating)][/COLOR]</label>
                        <align>left</align><aligny>center</aligny>
                    </control>
                    <control type="textbox"><left>447</left><top>52</top><width>783</width><height>30</height><font>font13</font><textcolor>FFCCCCCC</textcolor>
                        <label>$INFO[ListItem.Property(genre)]</label><align>left</align>
                    </control>
                    <control type="textbox"><left>447</left><top>92</top><width>783</width><height>250</height><font>font13</font><textcolor>FFFFFFFF</textcolor>
                        <label>$INFO[ListItem.Property(plot)]</label><autoscroll time="3000" delay="3000" repeat="3000">true</autoscroll><align>left</align>
                    </control>
                </focusedlayout>
            </control>
            <control type="button" id="30003">
                <top>40</top><right>40</right><height>50</height><width>50</width><aligny>center</aligny><align>center</align>
                <texturefocus colordiffuse="FFFFFFFF">close.png</texturefocus>
                <texturenofocus colordiffuse="80FFFFFF">close.png</texturenofocus>
                <ondown>30002</ondown>
            </control>
        </control>
    </controls>
</window>
